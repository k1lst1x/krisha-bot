# Krisha.kz account credentials
KRISHA_LOGIN=+7700...
KRISHA_PASSWORD=your_password

# Selenium / Chrome for Windows 7.
# Chrome 109 is the last practical Chrome line for Windows 7.
# If chromedriver.exe is not in PATH, uncomment and set the full path.
# KRISHA_CHROMEDRIVER=C:\path\to\chromedriver.exe
# KRISHA_CHROME_BINARY=C:\Program Files\Google\Chrome\Application\chrome.exe
KRISHA_CHROME_PROFILE_DIR=.krisha_chrome_profile

# Telegram bot (get token from @BotFather)
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_CHAT_ID=

# Phone numbers allowed to control the bot (comma or space separated)
TELEGRAM_ALLOWED_PHONES=+7700... +7701...

# Long-polling timeout (0 = short polling, 20 = recommended)
TELEGRAM_POLL_TIMEOUT_SEC=0

# Max run duration in seconds before process is killed (default 900)
TELEGRAM_RUN_TIMEOUT_SEC=900
